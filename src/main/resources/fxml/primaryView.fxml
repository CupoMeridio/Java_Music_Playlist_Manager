<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- 
    File FXML generato e gestito tramite SceneBuilder.
    Definisce la struttura dell'interfaccia utente principale.
    Collegato al controller it.unisa.java_music_playlist_manager.PrimaryViewController
-->

<BorderPane minHeight="600.0" minWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unisa.java_music_playlist_manager.PrimaryViewController">
   
   <!-- 1. BARRA LATERALE (LEFT) -->
   <left>
      <VBox prefWidth="220.0" spacing="15.0" style="-fx-border-color: #cccccc; -fx-border-width: 0 1 0 0;">
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="20.0" />
         </padding>
         <children>
            <!-- Titolo Applicazione (Opzionale) -->
            <Label style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Lettore musicale" />
            
            <!-- Barra di Ricerca -->
            <TextField fx:id="searchField" promptText="Cerca" />
            
            <!-- Pulsanti Principali Sidebar -->
            <VBox spacing="8.0" VBox.vgrow="ALWAYS">
               <children>
                  <Button fx:id="musicLibraryButton" maxWidth="Infinity" alignment="BASELINE_LEFT" text="Libreria musicale" onAction="#handleMusicLibraryAction" />
                  <Button fx:id="playQueueButton" maxWidth="Infinity" alignment="BASELINE_LEFT" text="Coda di riproduzione" onAction="#handlePlayQueueAction" />
                  <Button fx:id="playlistButton" maxWidth="Infinity" alignment="BASELINE_LEFT" text="Playlist" onAction="#handlePlaylistAction" />
               </children>
            </VBox>
         </children>
      </VBox>
   </left>
   
   <!-- 2. SEZIONE CENTRALE PRINCIPALE (CENTER) -->
   <center>
      <VBox spacing="20.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="25.0" right="25.0" top="20.0" />
         </padding>
         <children>
            <!-- Intestazione Superiore (Titolo e Azioni contestuali) -->
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <!-- Titolo Sezione Attiva -->
                  <Label fx:id="viewTitleLabel" style="-fx-font-size: 28px; -fx-font-weight: bold;" text="Musica" />
                  
                  <!-- Spaziatore per spingere il bottone a destra -->
                  <Region HBox.hgrow="ALWAYS" />
                  
                  <!-- Bottone d'azione dinamico (Aggiungi brano / Nuova playlist) -->
                  <Button fx:id="actionButton" onAction="#handleActionBtnClick" text="Aggiungi brano" />
               </children>
            </HBox>
            
            <!-- Barra di Controllo Playlist / Ordinamento -->
            <HBox alignment="CENTER_LEFT" spacing="15.0">
               <children>
                  <!-- Pulsante Riproduzione Casuale Completa -->
                  <Button fx:id="shufflePlayButton" style="-fx-font-weight: bold;" text="Riproduzione casuale" onAction="#handleShufflePlayAction" />
                  
                  <!-- Spaziatore per spingere gli ordinamenti a destra -->
                  <Region HBox.hgrow="ALWAYS" />
                  
                  <!-- Controlli di Ordinamento e Genere (Sulla destra) -->
                  <HBox alignment="CENTER_RIGHT" spacing="10.0">
                     <children>
                        <Label text="Ordina per:" />
                        <ComboBox fx:id="sortComboBox" promptText="A - Z" />
                        
                        <HBox fx:id="genreFilterContainer" alignment="CENTER_RIGHT" spacing="10.0">
                           <children>
                              <Label text="Genere:" />
                              <ComboBox fx:id="genreComboBox" promptText="Tutti i generi" />
                           </children>
                        </HBox>
                     </children>
                  </HBox>
               </children>
            </HBox>
            
            <!-- Tabella per l'elenco dei Brani (TableView) -->
            <TableView fx:id="songTableView" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="titleColumn" prefWidth="200.0" text="Titolo" />
                  <TableColumn fx:id="artistColumn" prefWidth="150.0" text="Artista" />
                  <TableColumn fx:id="albumColumn" prefWidth="150.0" text="Album" />
                  <TableColumn fx:id="yearColumn" prefWidth="80.0" text="Anno" />
                  <TableColumn fx:id="genreColumn" prefWidth="120.0" text="Genere" />
                  <TableColumn fx:id="durationColumn" prefWidth="80.0" text="Durata" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </center>
   
   <!-- 3. BARRA DI RIPRODUZIONE IN BASSO (BOTTOM) -->
   <bottom>
      <VBox spacing="10.0" style="-fx-border-color: #cccccc; -fx-border-width: 1 0 0 0;">
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="10.0" />
         </padding>
         <children>
            <!-- Riga 1: Barra di Progresso (Timeline) con Tempi -->
            <HBox alignment="CENTER" spacing="10.0">
               <children>
                  <Label fx:id="currentTimeLabel" text="00:00:00" />
                  <Slider fx:id="progressSlider" HBox.hgrow="ALWAYS" />
                  <Label fx:id="totalTimeLabel" text="00:00:00" />
               </children>
            </HBox>
            
            <!-- Riga 2: Dettagli Brano, Controlli Riproduzione, Volume e Opzioni -->
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  
                  <!-- Lato Sinistro: Copertina e Info Traccia -->
                  <HBox alignment="CENTER_LEFT" prefWidth="250.0" spacing="10.0" HBox.hgrow="NEVER">
                     <children>
                        <!-- Copertina del Brano -->
                        <ImageView fx:id="albumCoverImageView" fitHeight="50.0" fitWidth="50.0" pickOnBounds="true" preserveRatio="true" style="-fx-border-color: #999999; -fx-border-width: 1;">
                           <!-- Image placeholder can be loaded programmatically -->
                        </ImageView>
                        
                        <!-- Metadati del Brano (Titolo e Artista) -->
                        <VBox alignment="CENTER_LEFT" spacing="3.0">
                           <children>
                              <Label fx:id="currentTrackTitle" style="-fx-font-weight: bold;" text="" />
                              <Label fx:id="currentTrackDetails" style="-fx-font-size: 11px;" text="" textOverrun="ELLIPSIS" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  
                  <!-- Spaziatore a sinistra per centrare i controlli -->
                  <Region HBox.hgrow="ALWAYS" />
                  
                  <!-- Centro: Controlli Riproduzione (Casuale, Indietro, Play/Pausa, Avanti, Ciclo) -->
                  <HBox alignment="CENTER" spacing="15.0" HBox.hgrow="NEVER">
                     <children>
                        <Button fx:id="shuffleButton" text="🔀" onAction="#handleShuffleToggle" />
                        <Button fx:id="prevButton" text="⏮" onAction="#handlePrevAction" />
                        <Button fx:id="playPauseButton" style="-fx-font-size: 16px; -fx-font-weight: bold;" text="▶" onAction="#handlePlayPauseAction" />
                        <Button fx:id="nextButton" text="⏭" onAction="#handleNextAction" />
                        <Button fx:id="repeatButton" text="🔁" onAction="#handleRepeatToggle" />
                     </children>
                  </HBox>
                  
                  <!-- Spaziatore a destra per spingere il volume a destra -->
                  <Region HBox.hgrow="ALWAYS" />
                  
                  <!-- Lato Destro: Volume -->
                  <HBox alignment="CENTER_RIGHT" prefWidth="250.0" spacing="10.0" HBox.hgrow="NEVER">
                     <children>
                        <!-- Controllo Volume -->
                        <Button fx:id="volumeButton" text="🔊" onAction="#handleVolumeMuteToggle" />
                        <Slider fx:id="volumeSlider" max="100.0" prefWidth="100.0" value="50.0" />
                     </children>
                  </HBox>
                  
               </children>
            </HBox>
         </children>
      </VBox>
   </bottom>
   
</BorderPane>
